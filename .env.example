# Spotify App credentials (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Server
PORT=3001
CLIENT_URL=http://127.0.0.1:5173

# Client (prefix with VITE_ for Vite to expose them)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SERVER_URL=http://127.0.0.1:3001
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/spotify-callback
